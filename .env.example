# WealthIQ Environment Variables
# Copy this to .env.local and fill in the values

# Claude API key for AI insight generation
# Get yours at: https://console.anthropic.com
# Optional — the app works without it using fallback insights
ANTHROPIC_API_KEY=sk-ant-...

# Production base URL (used for canonical URLs and OG image generation)
NEXT_PUBLIC_BASE_URL=https://wealthiq.co.il

# Optional: Analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=wealthiq.co.il
